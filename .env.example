# Arunya Foundation - Environment Variables Example
# Copy this file to .env.local and fill in your values

# ============================================================
# Firebase Configuration
# ============================================================
# Get these values from your Firebase Console:
# https://console.firebase.google.com/project/YOUR-PROJECT-ID/settings/iam-security

VITE_FIREBASE_API_KEY=AIzaSyD...your_api_key_here...
VITE_FIREBASE_AUTH_DOMAIN=arunya-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=arunya-project
VITE_FIREBASE_STORAGE_BUCKET=arunya-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ============================================================
# API Configuration
# ============================================================
# Your backend API base URL
VITE_API_BASE_URL=https://api.arunya.org

# ============================================================
# App Configuration
# ============================================================
# Set to true when you want to enable Firebase features
VITE_ENABLE_FIREBASE=false
VITE_ENABLE_ANALYTICS=false

# ============================================================
# Development Settings
# ============================================================
# Use this for development/testing
VITE_ENV=development
VITE_DEBUG=false

# ============================================================
# Gemini AI Configuration
# ============================================================
# Get your API key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
